<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <RootNamespace>Solas.Build</RootNamespace>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild> <PackageId>Solas.Build</PackageId>
        <Version>0.2.0</Version>
        <Authors>NevskyV</Authors>
        <Description>Lightweight build tool for Solas projects</Description>
        <RepositoryUrl>https://github.com/NevskyV/Solas</RepositoryUrl>
        <PackageLicenseExpression>MPL-2.0</PackageLicenseExpression>
        <PackageIcon>SolasBuildIcon.png</PackageIcon>
        <PackageReadmeFile>README_SIMPLE.md</PackageReadmeFile>

        <PackAsTool>true</PackAsTool>
        <ToolCommandName>slsbuild</ToolCommandName>
        <IsRoslynComponentAnalyzer>false</IsRoslynComponentAnalyzer>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Solas.Core" />

        <None Include="..\README_SIMPLE.md" Pack="true" PackagePath="\"/>
        <None Include="SolasBuildIcon.png" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
