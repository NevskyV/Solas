<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <RootNamespace>Solas.Build</RootNamespace>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild> <PackageId>Solas.Build</PackageId>
        <Version>0.1.0</Version>
        <Authors>NevskyV</Authors>
        <Description>High performance open-source .net game engine created specifically for indie devs</Description>
        <RepositoryUrl>https://github.com/NevskyV/Solas</RepositoryUrl>
        <PackageLicenseExpression>MPL-2.0</PackageLicenseExpression>

        <PackAsTool>true</PackAsTool>
        <ToolCommandName>slsbuild</ToolCommandName>

        <IsRoslynComponentAnalyzer>false</IsRoslynComponentAnalyzer>

        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Solas.Core" Version="0.1.*" />

        <None Include="..\README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
